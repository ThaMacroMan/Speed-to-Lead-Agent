# Required: Formspree form ID (from your form URL or Formspree dashboard)
FORMSPREE_FORM_ID=your-form-id

PORT=3000
NODE_ENV=production

DATA_DIR=./data
REDIS_URL=redis://redis:6379
WORKER_ENABLED=true

# Required for AI replies
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Required for SMS (and voice if enabled)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: email channel (leave empty to use SMS/voice only)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Speed To Lead

BOOKING_LINK=https://calendly.com/your-handle/meet-greet
BUSINESS_TIMEZONE=America/New_York
QUIET_HOURS_START=20
QUIET_HOURS_END=8
DRY_RUN=false
ENABLE_VOICE=false
