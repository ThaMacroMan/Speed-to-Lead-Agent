{
  "name": "speed-to-lead",
  "version": "1.0.0",
  "private": true,
  "description": "Dockerized speed-to-lead agent backend with filesystem memory",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bullmq": "^5.70.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "ioredis": "^5.10.0",
    "openai": "^4.104.0",
    "proper-lockfile": "^4.1.2",
    "twilio": "^4.23.0",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/proper-lockfile": "^4.1.4",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.35.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
